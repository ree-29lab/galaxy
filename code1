let ball=[];

//ball.push("Sun");

function setup(){
	createCanvas(600,600);
	background(220);
	
}
function draw(){
	for(let i=0;i<ball.length;i++){
		let b =ball[i];
		fill(b.color);
		circle(b.x,b.y,b.size);
	}
	
}

function mousePressed(){
	
	ball.push({
	x:mouseX,
	y:mouseY,
	size:random(50),
	color:[random(255),random(255),random(255)],
		
})
	
}
